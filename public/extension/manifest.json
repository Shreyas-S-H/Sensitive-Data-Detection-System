{
  "manifest_version": 3,
  "name": "Smart Privacy Guard",
  "version": "1.0",
  "description": "Protects your sensitive data by detecting and masking sensitive information in documents.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
