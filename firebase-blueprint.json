{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered user of the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "Scan": {
      "title": "Scan",
      "description": "Record of a document scan session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "detectionsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fileName", "fileType", "detectionsCount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/scans/{scanId}": {
      "schema": "Scan",
      "description": "User scan history"
    }
  }
}
